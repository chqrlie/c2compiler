module label_map;

import ir;

import stdlib;
import string;

public type Entry struct {
    u32 key;
    ir.BlockId goto_id;
    ir.BlockId break_id;
    ir.BlockId continue_id;
}

public type Map struct {
    Entry* entries;
    u32 count;
    u32 capacity;
}

public fn void Map.init(Map* l) {
    string.memset(l, 0, sizeof(Map));
    l.resize(8);
}

public fn void Map.free(Map* l) {
    stdlib.free(l.entries);
}

public fn void Map.clear(Map* l) {
    l.count = 0;
}

public fn void Map.add(Map* l, u32 key, ir.BlockId goto_id) {
    // Note: we dont check for duplicates here
    if (l.count == l.capacity) l.resize(l.capacity * 2);
    Entry* v = &l.entries[l.count];
    v.key = key;
    v.goto_id = goto_id;
    v.break_id = 0;
    v.continue_id = 0;
    l.count++;
}

public fn void Map.add2(Map* l, u32 key, ir.BlockId break_id, ir.BlockId continue_id) {
    // Note: entry might already be created by goto
    for (u32 i=0; i<l.count; i++) {
        Entry* v = &l.entries[i];
        if (v.key == key) {
            v.break_id = break_id;
            v.continue_id = continue_id;
            return;
        }
    }

    if (l.count == l.capacity) l.resize(l.capacity * 2);
    Entry* v = &l.entries[l.count];
    v.key = key;
    v.goto_id = 0;
    v.break_id = break_id;
    v.continue_id = continue_id;
    l.count++;
}

// Note: if value 0 is not a valid one, dont need to check with contains() first
public fn ir.BlockId Map.getGoto(const Map* l, u32 key) {
    for (u32 i=0; i<l.count; i++) {
        if (l.entries[i].key == key) return l.entries[i].goto_id;
    }
    return 0;
}

public fn ir.BlockId Map.getBreak(const Map* l, u32 key) {
    for (u32 i=0; i<l.count; i++) {
        if (l.entries[i].key == key) return l.entries[i].break_id;
    }
    return 0;
}

public fn ir.BlockId Map.getContinue(const Map* l, u32 key) {
    for (u32 i=0; i<l.count; i++) {
        if (l.entries[i].key == key) return l.entries[i].continue_id;
    }
    return 0;
}

fn void Map.resize(Map* l, u32 cap) {
    l.capacity = cap;
    Entry* entries2 = stdlib.malloc(l.capacity * sizeof(Entry));
    if (l.count) string.memcpy(entries2, l.entries, l.count * sizeof(Entry));
    if (l.entries) stdlib.free(l.entries);
    l.entries = entries2;
}

