module ast;

import string_buffer;
import src_loc local;
import string;

type EnumTypeDeclBits struct {
    u32 : NumDeclBits;
    u32 is_incremental : 1;
    u32 is_regular : 1;
    u32 has_assoc_values : 1;
    u32 num_constants : 12;
}

public type EnumTypeDecl struct @(opaque) {
    Decl base;
    QualType implType;
    u16 num_enum_functions;
    u16 num_assoc_values;   // columns
    FunctionDecl** enum_functions;
    VarDecl** assoc_values;     // TODO make tail-allocated?
    VarDecl** assoc_decls;      // created during analysis
    EnumConstantDecl*[0] constants; // tail-allocated, for non-incremental enums
    EnumConstantDecl**[0] incr_constants; // tail-allocated, for incremental enums
}

public fn EnumTypeDecl* EnumTypeDecl.create(AstContext* c,
                                              u32 name,
                                              SrcLoc loc,
                                              bool is_public,
                                              u32 ast_idx,
                                              QualType implType,
                                              bool is_incremental,
                                              EnumConstantDecl** constants,
                                              u32 num_constants,
                                              VarDecl** assoc_values,
                                              u16 num_assoc_values)
{
    u32 size = sizeof(EnumTypeDecl) + num_constants * sizeof(EnumConstantDecl*);
    if (is_incremental) size += sizeof(EnumConstantDecl**);
    EnumTypeDecl* d = c.alloc(size, EnumTypeDecl);
    EnumType* etype = EnumType.create(c, d);
    QualType qt = QualType.create((Type*)etype);
    d.base.init(EnumType, name, loc, is_public, qt, ast_idx);
    d.base.enumTypeDeclBits.is_incremental = is_incremental;
    d.base.enumTypeDeclBits.has_assoc_values = (num_assoc_values != 0);
    d.base.enumTypeDeclBits.num_constants = num_constants;
    d.implType = implType;
    d.num_enum_functions = 0;
    d.num_assoc_values = num_assoc_values;
    d.enum_functions = nil;
    d.assoc_values = nil;
    d.assoc_decls = nil;

    if (is_incremental) {
        assert(num_constants == 0);
        d.incr_constants[0] = nil;
    } else {
        string.memcpy(d.constants, constants, num_constants * sizeof(EnumConstantDecl*));

        for (u32 i=0; i<num_constants; i++) {
            constants[i].asDecl().setType(qt);
        }
    }

    if (num_assoc_values) {
        u32 assoc_size = num_assoc_values * sizeof(VarDecl*);
        d.assoc_values = c.alloc(assoc_size, AssocValue);
        size += assoc_size;
        string.memcpy(d.assoc_values, assoc_values, assoc_size);
        d.assoc_decls = c.alloc(assoc_size, AssocValue);
        size += assoc_size;
        string.memset(d.assoc_decls, 0, assoc_size);
    }
    return d;
}

public fn void EnumTypeDecl.setRegular(EnumTypeDecl* d) {
    d.base.enumTypeDeclBits.is_regular = true;
}

public fn bool EnumTypeDecl.isRegular(const EnumTypeDecl* d) {
    return d.base.enumTypeDeclBits.is_regular;
}

