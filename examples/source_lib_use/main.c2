module test_main;

import foo;
import bar;

import stdio local;

public fn i32 main(i32 argc, char** argv) {
    i32 res = 1;
    res = foo.test2(argc);
    res += bar.test1(1);
    res += bar.test2(1);

    printf("test %d\n", res);

    return 0;
}
