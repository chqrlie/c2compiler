// @warnings{no-unused}
module test;

type Struct struct {
    i32[4] x;
}

i32[3] y;

Struct s;

fn void test1() {
    i32[2] z;

    i8 a = countof(z);
    i8 b = countof(y);
    i8 c = countof(s.x);
    i8 d = countof(test.s.x);
    i8 e = countof(test.y);
    i8 f = countof(test.s);       // @error{countof can only be used on arrays/enums}

    // Not supported (yet)
    //i8 g = countof(Struct.x);
    //i8 h = countof(test.Struct.x);
}

