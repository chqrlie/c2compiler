// @warnings{no-unused}
module test;

type Enum1 enum i8 {
    AA = -2,
    DD = -1,
}

const u32 E = Enum1.max;  // @error{constant value -1 out-of-bounds for type 'u32', range [0, 4294967295]}
const u32 F = Enum1.min;  // @error{constant value -2 out-of-bounds for type 'u32', range [0, 4294967295]}

