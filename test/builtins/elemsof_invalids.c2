// @warnings{no-unused}
module test;

type Struct struct {
    i32 x;
}

fn void test1() {
    i32 ii;
    i32 a = countof(ii);      // @error{countof can only be used on arrays/enums}
}

fn void test3() {
    Struct ss;
    i32 c = countof(ss);     // @error{countof can only be used on arrays/enums}
}

fn void test4() {
    i32 d = countof(test1);  // @error{countof can only be used on arrays/enums}
}

fn void test5() {
    i32[4] aa;
    i32 f = countof(aa);
}

fn void test6() {
    i32 e = countof(test);   // @error{countof can only be used on arrays/enums}
}

