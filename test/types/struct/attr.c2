// @warnings{no-unused-type}
module test;

type Foo struct {
    i32 a;
    i32 b @(unused);
    i32 : 4 @(unused);
    i32 c : 4 @(unused);
    fn bool (i32 a, void* b) d @(unused);
    char e; // @warning{unused struct member 'e'}
}

public fn i32 main() {
    Foo f;
    f.a = 1;
    return f.a;
}

