// @recipe bin
    $warnings no-unused
    $backend c no-build fast

// @file{file1}
module mod1;

type Foo struct {
    i32 x;
}

public type Enum enum u8 (public i32 a, Foo f) {
    A : { 10, { 1 } },
    B : { 20, { 2 } },
}

// @file{file2}
module mod2;

import mod1 local;

fn void test1(Enum e) {
    i32 a = e.a;
}

// @expect{atleast, cgen/mod1.h}

typedef u8 mod1_Enum;
enum mod1_Enum {
   mod1_Enum_A,
   mod1_Enum_B,
};

extern int mod1_Enum__a[2];

// @expect{atleast, cgen/mod1.c}

typedef struct mod1_Foo_ mod1_Foo;

struct mod1_Foo_ {
   int x;
};

int mod1_Enum__a[2] = { 10, 20 };
static mod1_Foo mod1_Enum__f[2] = {
   { 1 },
   { 2 }
};

