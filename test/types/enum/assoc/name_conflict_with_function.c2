// @warnings{no-unused}
module test;

type Enum enum u8 (const char* str) {   // @note{previous definition is here}
    A : { "a" },
    B : { "bb" },
    C : { "ccc" },
}

fn const char* Enum.str(Enum e) {   // @error{redefinition of 'test.Enum.str'}
    switch (e) {
    case A: return "A";
    case B: return "B";
    case C: return "C";
    }
    return "";
}

